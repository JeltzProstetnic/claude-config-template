#!/usr/bin/env bash
# sync.local.sh — User-specific overrides for sync.sh
# Copy this file to sync.local.sh and customize.
# sync.local.sh is gitignored and never touched by upgrades.

# Map hostname to machine file name
# Called by sync.sh cmd_setup() when auto-detecting machine
local_hostname_map() {
    local hn="$1"
    case "$hn" in
        # my-vps-*)       echo "vps.md" ;;
        # DESKTOP-*)      echo "wsl.md" ;;
        # steamdeck*)     echo "steamdeck.md" ;;
        # my-workstation*)
        #     if [[ "$(whoami)" == "work-user" ]]; then
        #         echo "office.md"
        #     else
        #         echo "home.md"
        #     fi
        #     ;;
        *) ;;  # No match — falls through to framework defaults
    esac
}

