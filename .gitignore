# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Secrets — never commit these
.env
.env.*
*.key
*.pem
# secrets/ has its own .gitignore (tracks scaffold, ignores actual secrets)
credentials/

# Temporary files (review outputs, scratch)
tmp/

# Logs
*.log
logs/

# Node
node_modules/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Build output
dist/
build/

# LaTeX artifacts
*.aux
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz

# Editor swap
*.kate-swp

# Setup marker (transient, per-machine)
.setup-pending

# Machine catalog (auto-generated, per-machine)
machine-catalog.md

# Runtime session state (created at first use, not needed in template)
session-context.md
session-history.md

# Runtime project state (created by first-run refinement, per-user)
backlog.md
registry.md
