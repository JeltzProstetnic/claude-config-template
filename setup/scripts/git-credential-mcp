#!/usr/bin/env bash
# Git credential helper that reads GitHub PAT from MCP config.
# Checks cc-mirror config first, falls back to ~/.mcp.json.
#
# Supports multiple GitHub accounts:
#   - Default (no username or x-access-token): uses 'github' server token
#   - Secondary username (e.g., work account): uses secondary MCP server token (falls back to personal)
#
# To add a secondary account:
#   1. Add a secondary MCP server in your .mcp.json with its own GITHUB_PERSONAL_ACCESS_TOKEN
#   2. Set SECONDARY_GITHUB_USER and SECONDARY_MCP_SERVER below
#   3. Configure git remotes with the secondary username: git remote set-url origin https://WorkUser@github.com/org/repo.git

[ "$1" != "get" ] && exit 0

# --- Customize these for your secondary GitHub account ---
# Leave empty if you only use one GitHub account
SECONDARY_GITHUB_USER="${SECONDARY_GITHUB_USER:-}"       # e.g., "WorkUser"
SECONDARY_MCP_SERVER="${SECONDARY_MCP_SERVER:-}"          # e.g., "github-work"

host=""
username=""
while IFS='=' read -r key value; do
    [ "$key" = "host" ] && host="$value"
    [ "$key" = "username" ] && username="$value"
done

[ "$host" != "github.com" ] && exit 0

# Find MCP config: cc-mirror first, then global fallback
MCP_CONFIG=""
for candidate in \
    "$HOME/.cc-mirror/"*/config/.mcp.json \
    "$HOME/.mcp.json"; do
    [ -f "$candidate" ] && MCP_CONFIG="$candidate" && break
done
[ -z "$MCP_CONFIG" ] && exit 1

# Route by username to the correct MCP server
result=$(python3 -c "
import json, sys

mcp_path, req_user = sys.argv[1], sys.argv[2]
secondary_user = sys.argv[3] if len(sys.argv) > 3 else ''
secondary_server = sys.argv[4] if len(sys.argv) > 4 else ''

d = json.load(open(mcp_path))
servers = d.get('mcpServers', {})

# Determine which server and username to use
if secondary_user and req_user == secondary_user and secondary_server:
    # Try secondary server first, fall back to personal
    if secondary_server in servers:
        token = servers[secondary_server]['env']['GITHUB_PERSONAL_ACCESS_TOKEN']
        out_user = secondary_user
    else:
        token = servers['github']['env']['GITHUB_PERSONAL_ACCESS_TOKEN']
        out_user = 'x-access-token'
else:
    token = servers['github']['env']['GITHUB_PERSONAL_ACCESS_TOKEN']
    out_user = 'x-access-token'

sys.stdout.write(f'protocol=https\nhost=github.com\nusername={out_user}\npassword={token}\n')
" "$MCP_CONFIG" "$username" "$SECONDARY_GITHUB_USER" "$SECONDARY_MCP_SERVER") || exit 1

printf '%s' "$result"
